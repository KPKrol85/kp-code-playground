{
  "name": "easy-move-site",
  "version": "1.0.0",
  "description": "Premium multi-page website for Easy Move moving company.",
  "type": "module",
  "scripts": {
    "build:css": "postcss css/main.css -o dist/css/main.min.css",
    "build:js": "node scripts/build-js.mjs",
    "build:dist": "node scripts/build.mjs",
    "build": "npm run build:dist",
    "css:watch": "postcss css/main.css -o dist/css/main.min.css --watch",
    "dev": "vite --host",
    "images:convert": "node scripts/convert-images.mjs",
    "preview": "npm run build && vite preview --host"
  },
  "devDependencies": {
    "cssnano": "^6.1.2",
    "postcss": "^8.4.38",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^16.1.0",
    "terser": "^5.30.3",
    "vite": "^5.2.0"
  },
  "dependencies": {
    "sharp": "^0.33.3"
  }
}
