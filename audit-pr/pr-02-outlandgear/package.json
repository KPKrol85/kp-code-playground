{
  "name": "outlandgear",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:css": "postcss css/main.css -o css/main.min.css",
    "build:js": "esbuild js/app.js --bundle --minify --outfile=js/app.min.js",
    "build": "npm run build:css && npm run build:js",
    "watch:css": "postcss css/main.css -o css/main.min.css --watch",
    "watch:js": "esbuild js/app.js --bundle --minify --outfile=js/app.min.js --watch"
  },
  "devDependencies": {
    "cssnano": "^7.0.7",
    "esbuild": "^0.25.11",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1"
  }
}
